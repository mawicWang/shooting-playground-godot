# Godot-specific ignores
# ----------------------
# Godot 4+ 核心缓存文件夹（包含导入的资产数据和元数据）
.godot/

# Godot 3 核心缓存文件夹
.import/

# 编辑器特定的设置（如打开过的脚本、窗口布局等）
# 如果你希望在不同电脑间同步编辑器的脚本编辑状态，可以注释掉这一行
# 但通常建议排除以避免频繁的 Git 变动
# .godot/editor/ 

# 导出生成的各类二进制文件
*.tmp
*.pck
*.exe
*.zip
*.apk
*.ipa
*.app
*.dmg
# Web export files (except web directory)
!web/*.html
!web/*.js
!web/*.wasm
!web/*.pck
!web/*.png

# 排除自动生成的导出配置文件（可选）
# 如果你的导出设置包含敏感密钥，请取消注释
# export_presets.cfg

# 硬件加速与单机特定文件
# ----------------------
# 排除 mono/C# 项目的构建产物
.mono/
bin/
obj/
# 排除 C# 方案文件（如果你习惯每个人在本地生成方案）
# *.sln
# *.csproj

# Netlify CLI 本地状态
# ----------------------
.netlify/
web/.netlify/

# Wrangler (Cloudflare CLI) 本地缓存
# ----------------------
.wrangler/

# 通用系统文件
# ----------------------
.DS_Store
Thumbs.db

# 各种日志
# ----------------------
*.log

# 防止 Godot 自动保存产生的根目录残留文件
# ----------------------
/bullet.tscn
/enemy.tscn
/enemy_warning.tscn
/tower.tscn
/enemy_shader.gdshader
/enemy_shader.gdshader.uid
/removal_zone.gd

# Worktrees for isolated development
# ----------------------
.worktrees/

/reports